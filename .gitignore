# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Nested app build output
**/.next/
admin/.next/

# Deploy-time vendored snapshot of packages/core. The admin app resolves
# @core/* from admin/vendor-core during Vercel builds where the project root is
# admin/, so this snapshot is intentionally committed. Refresh it with:
# node scripts/sync-vendor-core.mjs

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Nested app build output
**/.next/
admin/.next/

# Deploy-time vendored snapshot of packages/core (admin/ needs a self-
# contained upload since Vercel CLI deploys ignore Root Directory settings
# without real GitHub-integration git linking). Re-copy before redeploying
# if packages/core changes: cp -R packages/core/src/* admin/vendor-core/
admin/vendor-core/
